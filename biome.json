{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"files": {
		"includes": [
			"**",
			"!node_modules",
			"!out",
			"!dist",
			"!.vscode-test",
			"!.nyc_output",
			"!coverage",
			"!.claude",
			"!*.md",
			"!*.yml",
			"!*.yaml",
			"!package-lock.json"
		]
	},
	"linter": {
		"rules": {
			"preset": "recommended"
		}
	},
	"formatter": {
		"enabled": true
	}
}
